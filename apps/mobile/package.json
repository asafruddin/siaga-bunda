{
  "name": "@siaga-bunda/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo start --dev-client --android",
    "build": "expo export --platform android --output-dir dist --clear",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "lint": "expo lint",
    "doctor": "expo-doctor"
  },
  "dependencies": {
    "expo": "~56.0.13",
    "expo-build-properties": "~56.0.20",
    "expo-constants": "~56.0.19",
    "expo-dev-client": "~56.0.21",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.12",
    "expo-splash-screen": "~56.0.11",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/react": "~19.2.17",
    "eslint": "9.39.3",
    "eslint-config-expo": "~56.0.4",
    "expo-doctor": "1.20.0",
    "tsx": "4.20.6",
    "typescript": "~6.0.3"
  }
}
